rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && (
          userDoc().data.cargo in ['ADMIN', 'admin', 'gerente', 'GERENTE', 'Gerente Geral', 'GERENTE GERAL']
          || userDoc().data.cargoNormalizado in ['admin', 'gerente', 'gerente geral']
        );
    }

    function isBootstrapAdmin() {
      return signedIn()
        && request.auth.token.email in ['limaalecsander@gmail.com'];
    }

    function isBackupOperator() {
      return isAdmin()
        || isBootstrapAdmin()
        || (isApprovedUser() && hasRole(['gerente', 'GERENTE', 'Gerente Geral', 'GERENTE GERAL', 'gerente geral', 'admin', 'ADMIN']));
    }

    function isSafeSelfUserUpdate(userId) {
      return signedIn()
        && userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['nome', 'email', 'uid', 'atualizadoEm', 'online', 'ultimoAcessoEm', 'ultimaAtividadeEm', 'onlineAtualizadoEm']);
    }

    function isSafeSelfUserCreate(userId) {
      return signedIn()
        && userId == request.auth.uid
        && request.resource.data.cargo in ['PENDENTE', 'pendente'];
    }

    function isApprovedUser() {
      return signedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && !(userDoc().data.cargo in ['PENDENTE', 'pendente']);
    }

    function userRole() {
      return userDoc().data.cargoNormalizado != null
        ? userDoc().data.cargoNormalizado
        : userDoc().data.cargo;
    }

    function hasRole(roles) {
      return userRole() in roles;
    }

    function hasCustomPermissionList(listName) {
      return 'permissoes' in userDoc().data
        && listName in userDoc().data.permissoes
        && userDoc().data.permissoes[listName] is list;
    }

    function collectionMatchesSections(collection, sections) {
      return
        ((collection in ['clientes']) && 'view-clientes' in sections)
        || ((collection in ['clientes_subprodutos', 'vendas_subprodutos']) && 'view-cavaco' in sections)
        || ((collection in ['romaneios']) && 'view-romaneio-v2' in sections)
        || ((collection in ['historico', 'romaneios', 'vendas_subprodutos']) && 'view-historico' in sections)
        || ((collection in ['transportes']) && 'view-transportes' in sections)
        || ((collection in ['empreiteiros', 'entradas']) && 'view-entrada' in sections)
        || ((collection in ['produtos']) && 'view-produtos' in sections)
        || ((collection in ['estoque', 'estoque_movimentacoes']) && 'view-estoque' in sections)
        || ((collection in ['frotas', 'frota_abastecimentos', 'frota_manutencoes']) && 'view-frotas' in sections)
        || ((collection in ['financeiro_lancamentos', 'financeiro_relatorios_mensais']) && 'view-financeiro' in sections)
        || ((collection in ['funcionarios']) && 'view-rh' in sections)
        || ((collection in ['agenda']) && 'view-agenda' in sections)
        || ((collection in ['patio_relatorios']) && ('view-dashboard' in sections || 'view-romaneio-v2' in sections))
        || ((collection in ['auditoria_logs']) && 'view-configuracoes' in sections)
        || ((collection in ['usuarios']) && 'view-configuracoes' in sections);
    }

    function canReadByCustomPermission(collection) {
      return hasCustomPermissionList('allowedSections')
        && collectionMatchesSections(collection, userDoc().data.permissoes.allowedSections);
    }

    function canWriteByCustomPermission(collection) {
      return hasCustomPermissionList('writeSections')
        && collectionMatchesSections(collection, userDoc().data.permissoes.writeSections);
    }

    function canWriteFluxoPatio(collection) {
      return collection == 'patio_relatorios'
        && isApprovedUser()
        && (
          hasRole(['empilhaderista', 'EMPILHADEIRISTA', 'Empilhaderista'])
          || (
            'permissoes' in userDoc().data
            && 'allowedSections' in userDoc().data.permissoes
            && ('view-dashboard' in userDoc().data.permissoes.allowedSections || 'view-romaneio-v2' in userDoc().data.permissoes.allowedSections)
          )
          || (
            'permissoes' in userDoc().data
            && 'allowedSubsections' in userDoc().data.permissoes
            && 'view-dashboard' in userDoc().data.permissoes.allowedSubsections
            && 'fluxo-patio' in userDoc().data.permissoes.allowedSubsections['view-dashboard']
          )
          || (
            'permissoes' in userDoc().data
            && 'writeSections' in userDoc().data.permissoes
            && ('view-dashboard' in userDoc().data.permissoes.writeSections || 'view-romaneio-v2' in userDoc().data.permissoes.writeSections)
          )
        );
    }

    function canDeleteByCustomPermission(collection) {
      return hasCustomPermissionList('deleteSections')
        && collectionMatchesSections(collection, userDoc().data.permissoes.deleteSections);
    }

    function canReadCollection(collection) {
      return isAdmin() || isBootstrapAdmin()
        || canReadByCustomPermission(collection)
        || (
        isApprovedUser() && (
          hasRole(['patrao', 'PATRÃO', 'Patrao', 'PATRÃO'])
          || (hasRole(['mecanico', 'MECANICO', 'Mecânico', 'Mecanico']) && collection in [
            'frotas',
            'frota_abastecimentos',
            'frota_manutencoes',
            'estoque',
            'estoque_movimentacoes',
            'financeiro_lancamentos'
          ])
          || (hasRole(['muqueiro', 'MUQUEIRO', 'Muqueiro']) && collection in [
            'empreiteiros',
            'entradas'
          ])
          || (hasRole(['estoquista', 'ESTOQUISTA', 'Estoquista']) && collection in [
            'estoque',
            'estoque_movimentacoes',
            'frotas',
            'frota_abastecimentos',
            'frota_manutencoes'
          ])
          || (hasRole(['gerente', 'GERENTE', 'Gerente Geral', 'GERENTE GERAL', 'gerente geral', 'admin', 'ADMIN']) && collection in [
            'clientes',
            'clientes_subprodutos',
            'produtos',
            'transportes',
            'empreiteiros',
            'entradas',
            'romaneios',
            'historico',
            'vendas_subprodutos',
            'patio_relatorios',
            'funcionarios',
            'agenda',
            'estoque',
            'estoque_movimentacoes',
            'frotas',
            'frota_abastecimentos',
            'frota_manutencoes',
            'financeiro_lancamentos',
            'financeiro_relatorios_mensais'
          ])
        )
      );
    }

    function canWriteCollection(collection) {
      return isAdmin() || isBootstrapAdmin()
        || canWriteFluxoPatio(collection)
        || canWriteByCustomPermission(collection)
        || (
        isApprovedUser() && (
          (hasRole(['mecanico', 'MECANICO', 'Mecânico', 'Mecanico']) && collection in [
            'frotas',
            'frota_abastecimentos',
            'frota_manutencoes',
            'estoque',
            'estoque_movimentacoes',
            'financeiro_lancamentos'
          ])
          || (hasRole(['muqueiro', 'MUQUEIRO', 'Muqueiro']) && collection in [
            'empreiteiros',
            'entradas'
          ])
          || (hasRole(['estoquista', 'ESTOQUISTA', 'Estoquista']) && collection in [
            'estoque',
            'estoque_movimentacoes'
          ])
          || (hasRole(['gerente', 'GERENTE', 'Gerente Geral', 'GERENTE GERAL', 'gerente geral', 'admin', 'ADMIN']) && collection in [
            'clientes',
            'clientes_subprodutos',
            'produtos',
            'transportes',
            'empreiteiros',
            'entradas',
            'romaneios',
            'historico',
            'vendas_subprodutos',
            'patio_relatorios',
            'funcionarios',
            'agenda',
            'estoque',
            'estoque_movimentacoes',
            'frotas',
            'frota_abastecimentos',
            'frota_manutencoes',
            'financeiro_lancamentos',
            'financeiro_relatorios_mensais'
          ])
        )
      );
    }

    function canDeleteCollection(collection) {
      return isAdmin() || isBootstrapAdmin()
        || canDeleteByCustomPermission(collection)
        || (
        isApprovedUser() && (
          (hasRole(['gerente', 'GERENTE', 'Gerente Geral', 'GERENTE GERAL', 'gerente geral', 'admin', 'ADMIN']) && collection in [
            'clientes',
            'clientes_subprodutos',
            'produtos',
            'transportes',
            'empreiteiros',
            'entradas',
            'romaneios',
            'historico',
            'vendas_subprodutos',
            'patio_relatorios',
            'funcionarios',
            'agenda',
            'estoque',
            'estoque_movimentacoes',
            'frotas',
            'frota_abastecimentos',
            'frota_manutencoes',
            'financeiro_lancamentos',
            'financeiro_relatorios_mensais'
          ])
        )
      );
    }

    function sameEmpresaOnRead() {
      return !('empresaId' in resource.data)
        || !('empresaId' in userDoc().data)
        || resource.data.empresaId == userDoc().data.empresaId;
    }

    function sameEmpresaOnWrite() {
      return !('empresaId' in request.resource.data)
        || !('empresaId' in userDoc().data)
        || request.resource.data.empresaId == userDoc().data.empresaId;
    }

    match /usuarios/{userId} {
      allow create: if isAdmin() || isBootstrapAdmin() || isSafeSelfUserCreate(userId);
      allow read: if signedIn() && (userId == request.auth.uid || isAdmin() || isBootstrapAdmin());
      allow update: if isAdmin() || isBootstrapAdmin() || isSafeSelfUserUpdate(userId);
      allow delete: if isAdmin() || isBootstrapAdmin();
    }

    match /backup_snapshots/{document} {
      allow read, delete: if isBackupOperator() && sameEmpresaOnRead();
      allow create, update: if isBackupOperator() && sameEmpresaOnWrite();
    }

    match /backup_snapshot_itens/{document} {
      allow read, delete: if isBackupOperator() && sameEmpresaOnRead();
      allow create, update: if isBackupOperator() && sameEmpresaOnWrite();
    }

    match /auditoria_logs/{document} {
      allow read: if isBackupOperator() && sameEmpresaOnRead();
      allow create: if isApprovedUser() && sameEmpresaOnWrite();
      allow update, delete: if false;
    }

    match /{collection}/{document} {
      allow read: if canReadCollection(collection)
        && (sameEmpresaOnRead() || collection == 'patio_relatorios')
        && collection in [
          'clientes',
          'clientes_subprodutos',
          'produtos',
          'transportes',
          'empreiteiros',
          'entradas',
          'romaneios',
          'historico',
          'vendas_subprodutos',
          'patio_relatorios',
          'funcionarios',
          'agenda',
          'estoque',
          'estoque_movimentacoes',
          'frotas',
          'frota_abastecimentos',
          'frota_manutencoes',
          'financeiro_lancamentos',
          'financeiro_relatorios_mensais'
        ];

      allow create, update: if canWriteCollection(collection)
        && (sameEmpresaOnWrite() || collection == 'patio_relatorios')
        && collection in [
          'clientes',
          'clientes_subprodutos',
          'produtos',
          'transportes',
          'empreiteiros',
          'entradas',
          'romaneios',
          'historico',
          'vendas_subprodutos',
          'patio_relatorios',
          'funcionarios',
          'agenda',
          'estoque',
          'estoque_movimentacoes',
          'frotas',
          'frota_abastecimentos',
          'frota_manutencoes',
          'financeiro_lancamentos',
          'financeiro_relatorios_mensais'
        ];

      allow delete: if canDeleteCollection(collection)
        && sameEmpresaOnRead()
        && collection in [
          'clientes',
          'clientes_subprodutos',
          'produtos',
          'transportes',
          'empreiteiros',
          'entradas',
          'romaneios',
          'historico',
          'vendas_subprodutos',
          'patio_relatorios',
          'funcionarios',
          'agenda',
          'estoque',
          'estoque_movimentacoes',
          'frotas',
          'frota_abastecimentos',
          'frota_manutencoes',
          'financeiro_lancamentos',
          'financeiro_relatorios_mensais'
        ];
    }
  }
}
